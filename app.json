{
  "expo": {
    "name": "FlavorDash",
    "slug": "FlavorDash",
    "version": "1.0.0",
    "scheme": "flavordash",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "FlavorDash memerlukan akses kamera untuk mengambil foto bukti pesanan."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FlavorDash memerlukan akses lokasi untuk menampilkan posisi Anda pada peta."
        }
      ]
    ],

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "FlavorDash memerlukan akses kamera untuk mengambil foto bukti pesanan.",
        "NSLocationWhenInUseUsageDescription": "FlavorDash memerlukan akses lokasi untuk menampilkan posisi Anda pada peta."
      }
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },

    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
